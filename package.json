{
  "name": "zt-react-milkdown",
  "version": "0.1.0",
  "description": "A React Markdown editor package powered by Milkdown.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "npm run dev:example",
    "dev:example": "pnpm --dir ./examples/react-playground dev",
    "dev:lib": "vite",
    "dev:reset": "node scripts/dev-reset.mjs && npm run setup:example && npm run build",
    "setup:example": "CI=true pnpm --dir ./examples/react-playground install --no-frozen-lockfile",
    "build": "npm run build:css && vite build",
    "build:css": "tailwindcss -i ./src/styles/style.css -o ./src/styles/generated.css --minify",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run",
    "test:watch": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest",
    "pack:check": "npm_config_cache=.npm-cache npm pack --dry-run"
  },
  "peerDependencies": {
    "@milkdown/kit": "^7.8.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.22",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "remark-math": "^6.0.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@tailwindcss/cli": "^4.1.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9"
  }
}
