{
  "name": "zt-react-milkdown",
  "version": "0.1.8",
  "description": "A React Markdown editor package powered by Milkdown.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "npm run dev:example",
    "dev:example": "cd ./examples/react-playground && vite --config ./vite.config.ts",
    "dev:lib": "vite",
    "dev:reset": "node scripts/dev-reset.mjs && npm run build",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run",
    "test:watch": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest",
    "pack:check": "npm_config_cache=.npm-cache npm pack --dry-run",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@milkdown/core": "^7.21.1",
    "@milkdown/ctx": "^7.21.1",
    "@milkdown/plugin-clipboard": "^7.21.1",
    "@milkdown/plugin-cursor": "^7.21.1",
    "@milkdown/plugin-history": "^7.21.1",
    "@milkdown/plugin-indent": "^7.21.1",
    "@milkdown/plugin-listener": "^7.21.1",
    "@milkdown/plugin-slash": "^7.21.1",
    "@milkdown/plugin-tooltip": "^7.21.1",
    "@milkdown/preset-commonmark": "^7.21.1",
    "@milkdown/preset-gfm": "^7.21.1",
    "@milkdown/prose": "^7.21.1",
    "@milkdown/react": "^7.21.1",
    "@milkdown/utils": "^7.21.1",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.46.1",
    "i18next": "^26.0.8",
    "katex": "^0.16.22",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "refractor": "5.0.0",
    "remark-math": "^6.0.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
